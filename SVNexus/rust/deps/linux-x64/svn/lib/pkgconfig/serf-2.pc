SERF_MAJOR_VERSION=2
prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include/serf-2

Name: serf
Description: HTTP client library
Version: 2.0.0
Requires.private: libssl libcrypto zlib
Libs: -L${libdir} -lserf-${SERF_MAJOR_VERSION}
Libs.private: -L/usr/local/svn/lib -lapr-2 -lcrypt -lrt -lpthread -ldl -lexpat
Cflags: -DLINUX -D_REENTRANT -D_GNU_SOURCE -pthread -I${includedir}
