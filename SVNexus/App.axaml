<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SVNexus.App"
             xmlns:local="using:SVNexus"
             xmlns:semi="https://irihi.tech/semi"
             xmlns:tab="clr-namespace:Tabalonia.Themes.Fluent;assembly=Tabalonia"
             xmlns:u-Semi="https://irihi.tech/ursa/themes/semi"
             xmlns:custom="clr-namespace:Tabalonia.Themes.Custom;assembly=Tabalonia"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

             <Application.Resources>
                 <ResourceDictionary>
                     <ResourceDictionary.MergedDictionaries>
                         <ResourceInclude Source="Resources/Style/CommonStyle.axaml"></ResourceInclude>
                         <ResourceInclude Source="Resources/Icons/Icons.axaml"></ResourceInclude>
                     </ResourceDictionary.MergedDictionaries>
                 </ResourceDictionary>
             </Application.Resources>
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <!-- <Application.Styles> -->
    <!--     <FluentTheme /> -->
             <!-- </Application.Styles> -->
     <Application.Styles>
         <semi:SemiTheme Locale="zh-CN" />
         <semi:ColorPickerSemiTheme />
         <semi:DataGridSemiTheme />
         <!-- <semi:TreeDataGridSemiTheme /> -->
         <semi:DockSemiTheme />
         <semi:AvaloniaEditSemiTheme />
         <u-Semi:SemiTheme Locale="zh-CN"/>
         <custom:CustomTheme></custom:CustomTheme>
     </Application.Styles>
</Application>