<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SVNexus.ViewModels"
             xmlns:u="https://irihi.tech/ursa"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:CheckoutOrExportProcessDialogModel"
             MinWidth="500"
             x:Class="SVNexus.Views.CheckoutOrExportProcessDialog">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="*, Auto">

        <StackPanel>
            <Border Theme="{StaticResource CardBorder}">
                <!-- <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto"> -->
                <!--     <TextBlock Grid.Row="0" Grid.Column="0" Text="仓库URL:"></TextBlock> -->
                <!--     <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Url}"></TextBlock> -->
                <!-- -->
                <!--     <TextBlock Grid.Row="1" Grid.Column="0" Text="本地路径:"></TextBlock> -->
                <!--     <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Path}"></TextBlock> -->
                <!-- -->
                <!--     <TextBlock Grid.Row="2" Grid.Column="0" Text="版本号:"></TextBlock> -->
                <!--     <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Revision}"></TextBlock> -->
                <!-- -->
                <!--     <TextBlock Grid.Row="3" Grid.Column="0" Text="用户名:"></TextBlock> -->
                <!--     <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Username}"></TextBlock> -->
                <!-- -->
                <!--     <TextBlock Grid.Row="4" Grid.Column="0" Text="开始时间:"></TextBlock> -->
                <!--     <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding StartTime}"></TextBlock> -->
                <!-- </Grid> -->
                <u:Descriptions HorizontalAlignment="Left">
                    <u:DescriptionsItem Label="仓库Url" Content="{Binding Url}" />
                    <u:DescriptionsItem Label="本地路径" Content="{Binding Path=Path}" />
                    <u:DescriptionsItem Label="版本号" Content="{Binding Revision}"></u:DescriptionsItem>
                    <u:DescriptionsItem Label="用户名" Content="{Binding Username}" />
                    <u:DescriptionsItem Label="开始时间" Content="{Binding StartTime}"></u:DescriptionsItem>
                </u:Descriptions>
            </Border>
            <Border Padding="8">

                <StackPanel>
                    <TextBlock Text="进度"></TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="当前文件:"></TextBlock>
                        <TextBlock TextWrapping="NoWrap"
                                   MaxWidth="400"
                                   TextTrimming="PrefixCharacterEllipsis" 
                                   Text="{Binding CurrentFile}"></TextBlock>
                    </StackPanel>
                    <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                        <TextBlock Text="进度:"></TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding ProcessText}"></TextBlock>
                        <Border Grid.Column="2"></Border>
                        <TextBlock Grid.Column="3" Text="已处理"></TextBlock>
                        <TextBlock Grid.Column="4" Text="{Binding HandleText}"></TextBlock>
                    </Grid>
                    <ProgressBar
                        Maximum="100"
                        Minimum="0"
                        Value="{Binding Process}"
                        IsIndeterminate="{Binding IsIndeterminate}"
                        ShowProgressText="True" />
                </StackPanel>
            </Border>
            <Expander Header="详细日志">
                <ListBox MaxHeight="250" ItemsSource="{Binding ProcessLogItems}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CheckoutOrExportProcessDialogModel+ProcessLogItemViewModel">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <TextBlock Margin="0 0 5 0" Grid.Column="0" Text="{Binding Action}"></TextBlock>
                                <HyperlinkButton Grid.Column="1" Content="{Binding Path}"></HyperlinkButton>
                                <TextBlock Grid.Column="2" Text="{Binding MimeType}"></TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Resources>
                        <Thickness x:Key="ListBoxItemDefaultPadding">0</Thickness>
                        <SolidColorBrush x:Key="ListBoxItemPointeroverBackground" Color="Transparent"></SolidColorBrush>
                        <SolidColorBrush x:Key="ListBoxItemPressedBackground" Color="Transparent"></SolidColorBrush>
                        <SolidColorBrush x:Key="ListBoxItemSelectedBackground" Color="Transparent"></SolidColorBrush>
                    </ListBox.Resources>
                </ListBox>
            </Expander>
        </StackPanel>
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto, Auto" Margin="0 10 0 0">
            <TextBlock Grid.Column="0" 
                       Text="{Binding Error}" 
                       Padding="4 0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SemiColorDanger}"></TextBlock>
            <Button Grid.Column="1" Content="关闭" IsVisible="{Binding Closable}" Command="{Binding CloseCommand}"></Button>
            <Border Grid.Column="2" Width="5"></Border>
            <Button Grid.Column="3" Content="打开" IsVisible="{Binding OpenButtonVisible}" Command="{Binding OpenRepositoryCommand}"></Button>
            <u:IconButton Grid.Column="4" 
                          Command="{Binding CancelCommand}"
                          Content="取消" 
                          Classes="Colorful Danger" 
                          IsLoading="{Binding IsCanceling}" 
                          IsEnabled="{Binding !IsCanceling}"
                          IsVisible="{Binding CancelButtonVisible}"></u:IconButton>
        </Grid>
        <!-- <StackPanel Margin="0 10 0 0" Grid.Row="1" Orientation="Horizontal" FlowDirection="RightToLeft" Spacing="4"> -->
        <!--     <Button Grid.Column="1" Content="关闭" IsVisible="{Binding Closable}" Command="{Binding ShutdownCommand}"></Button> -->
        <!--     <Button Grid.Column="2" Content="打开" IsVisible="{Binding OpenButtonVisible}" Command="{Binding OpenRepositoryCommand}"></Button> -->
        <!-- </StackPanel> -->
    </Grid>
</UserControl>
