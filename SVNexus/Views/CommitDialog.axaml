<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:viewModels="clr-namespace:SVNexus.ViewModels"
             xmlns:components="clr-namespace:SVNexus.Components"
             x:DataType="viewModels:CommitDialogModel"
             Width="800"
             IsEnabled="{Binding !CommitCommand.IsRunning}"
             x:Class="SVNexus.Views.CommitDialog">
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction Command="{Binding LoadedCommand}">
            </InvokeCommandAction>
        </EventTriggerBehavior>
    </Interaction.Behaviors>
    <UserControl.Resources>
        <Thickness x:Key="ThicknessCardMargin">0</Thickness>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="CornerRadius" Value="5"></Setter>
            <Setter Property="Padding" Value="0"></Setter>
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="*, Auto">
        <u:Form HorizontalAlignment="Stretch">
            <u:Form.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid RowDefinitions="Auto, Auto, Auto, *"></Grid>
                </ItemsPanelTemplate>
            </u:Form.ItemsPanel>
            <u:FormItem Grid.Row="0">
                <u:FormItem.Label>
                    <CheckBox IsChecked="{Binding ShowActualTargetItem}"
                              Content="Actual targets:"></CheckBox>
                </u:FormItem.Label>
                <Grid>
                    <Border Theme="{StaticResource CardBorder}" Padding="5">
                        <ListBox Height="150" ItemsSource="{Binding DisplayTargetItems}">
                            <!-- <ListBox.ItemTemplate> -->
                            <!--     <DataTemplate DataType="viewModels:CommitDialogModel+TargetItemViewModel"> -->
                            <!--         <components:TargetItem KindIcon="{Binding KindIcon}" -->
                            <!--                                     FileName="{Binding FileName}" -->
                            <!--                                     StatusIcon="{Binding  StatusIcon}" -->
                            <!--                                     StatusToolTip="{Binding StatusToolTip}" -->
                            <!--                                     > -->
                            <!--         </components:TargetItem> -->
                            <!--     </DataTemplate> -->
                            <!-- </ListBox.ItemTemplate> -->
                        </ListBox>
                    </Border>
                    <u:LoadingIcon Margin="0 0 10 10" 
                                   HorizontalAlignment="Right" 
                                   VerticalAlignment="Bottom"
                                   >
                        <u:LoadingIcon.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="IsLoading"></Binding>
                                <Binding Path="ShowActualTargetItem"></Binding>
                            </MultiBinding>
                        </u:LoadingIcon.IsVisible>
                    </u:LoadingIcon>
                </Grid>
            </u:FormItem>
            <u:FormItem Grid.Row="1" Label="Depth:">
                <u:EnumSelector HorizontalAlignment="Stretch"
                                Value="{Binding Depth}"
                                EnumType="{x:Static viewModels:CommitDialogModel.DepthType}">
                </u:EnumSelector>
            </u:FormItem>
            <u:FormItem Grid.Row="2" Label="Options:">
                <Grid ColumnDefinitions="*, *">
                    <CheckBox Grid.Column="0" Content="No lock" IsChecked="{Binding NoLock}"></CheckBox>
                    <CheckBox Grid.Column="1" Content="Include externals" IsChecked="{Binding IncludeExternals}"></CheckBox>
                </Grid>
            </u:FormItem>
            <u:FormItem Classes="GridLayout" Grid.Row="3" Label="Commit Message:">
                <TextBox ScrollViewer.VerticalScrollBarVisibility="Auto" 
                         TextWrapping="Wrap"
                         AcceptsReturn="True" Text="{Binding CommitMessage}"></TextBox>
            </u:FormItem>
        </u:Form>
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto">
            <Border Grid.Column="0"></Border>
            <Button Grid.Column="1" Content="取消" Command="{Binding CloseCommand}"></Button>
            <Border Grid.Column="2" Width="4"></Border>
            <u:IconButton Grid.Column="3"
                    Classes="Primary"
                    Theme="{StaticResource SolidIconButton}"
                    IsLoading="{Binding ConfirmCommand.IsRunning}"
                    Command="{Binding ConfirmCommand}"
                    Content="确定">
            </u:IconButton>
        </Grid>
    </Grid>
</UserControl>