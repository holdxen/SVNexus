<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:SVNexus.Components"
             xmlns:local="clr-namespace:SVNexus.ViewModels.WorkingCopy.Local"
             x:DataType="local:LocalListViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:inject="clr-namespace:SVNexus.Inject"
             inject:Ambient.WorkingCopyPath="{Binding WorkingCopyPath, Mode=OneWayToSource}"
             inject:Ambient.Guid="{Binding Token, Mode=OneWayToSource}"
             x:Class="SVNexus.Views.WorkingCopy.Local.LocalListView">
    <ListBox
        SelectedItem="{Binding SelectedItem}"
        SelectionMode="Multiple"
        ItemsSource="{Binding Items}">
        <ListBox.ItemTemplate>
            <DataTemplate x:DataType="local:LocalListViewModel+ListItemViewModel">
                <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                    <CheckBox Grid.Column="0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsChecked="{Binding IsChecked}">
                    </CheckBox>
                    <components:SvgRender Margin="2, 0"
                                          Grid.Column="1"
                                          Width="{Binding #ListItemText.Bounds.Height}"
                                          Height="{Binding #ListItemText.Bounds.Height}"
                                          Source="{Binding PathSvgIcon, Mode=OneWay}">
                    </components:SvgRender>
                    <TextBlock Grid.Column="2"
                               x:Name="ListItemText"
                               Text="{Binding Text}"
                               ToolTip.Tip="{Binding AbsolutePath}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center">
                    </TextBlock>
                    <ItemsControl Grid.Column="3"></ItemsControl>
                    <components:SvgRender
                        ToolTip.Tip="{Binding StatusToolTip, Mode=OneWay}"
                        Grid.Column="3"
                        Width="{Binding #ListItemText.Bounds.Height}"
                        Height="{Binding #ListItemText.Bounds.Height}"
                        Margin="3 0"
                        Source="{Binding StatusSvgIcon, Mode=OneWay}">
                    </components:SvgRender>

                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.Resources>
            <Thickness x:Key="ListBoxItemDefaultPadding">2 4</Thickness>
        </ListBox.Resources>
    </ListBox>
</UserControl>