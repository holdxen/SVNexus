<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:SVNexus.Components"
             xmlns:changes="clr-namespace:SVNexus.ViewModels.WorkingCopy.Changes"
             x:DataType="changes:ChangesListViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:converters="clr-namespace:SVNexus.Converters"
             x:Class="SVNexus.Views.WorkingCopy.Changes.ChangesListView">
    <UserControl.DataTemplates>
        <DataTemplate DataType="changes:ChangesListViewModel+MenuIconViewModel">
            <components:SvgRender Classes.Themable="{Binding Themable}"
                                  Source="{Binding Source, Converter={x:Static converters:StaticResourceConverter.Default}}"></components:SvgRender>
        </DataTemplate>
    </UserControl.DataTemplates>
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Show">
            <InvokeCommandAction Command="{Binding ShowCommand}">
            </InvokeCommandAction>
        </EventTriggerBehavior>
    </Interaction.Behaviors>
    <ListBox
        x:Name="ListBox"
        SelectedItem="{Binding SelectedItem}"
        SelectedItems="{Binding SelectedItems}"
        SelectionMode="Multiple"
        ItemsSource="{Binding Items}">
        <ListBox.Styles>
            <Style Selector="ListBoxItem">
                <Setter Property="CornerRadius" Value="5"></Setter>
                <Setter Property="Padding" Value="0"></Setter>
            </Style>
            <Style Selector="ListBoxItem:pressed">
                <Setter Property="Background" Value="{DynamicResource ListBoxItemPointeroverBackground}"></Setter>
            </Style>
            <Style Selector="ListBoxItem:selected">
                <Setter Property="Foreground" Value="{DynamicResource ListBoxItemSelectedForeground}" />
                <Setter Property="Background" Value="{DynamicResource ListBoxItemSelectedBackground}" />
                <Style Selector="^:pointerover">
                    <Setter Property="Background" Value="{DynamicResource ListBoxItemSelectedPointeroverBackground}" />
                </Style>
            </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
            <DataTemplate DataType="changes:ChangesListViewModel+ListItemViewModel">
                <components:StatusEntryItem
                    KindIcon="{Binding KindIcon}"
                    FileName="{Binding FileName}"
                    IsLocked="{Binding IsLocked}"
                    ShowRelateDirectory="True"
                    RelativeDirectory="{Binding RelativeDirectory}"
                    TextToolTip="{Binding AbsolutePath}"
                    StatusIcon="{Binding StatusIcon}"
                    IsDelete="{Binding IsDelete}"
                    StatusToolTip="{Binding StatusToolTip}">
                </components:StatusEntryItem>
                <!-- <Border Classes="StatusEntryItem" Name="ItemRoot"> -->
                <!--     <Grid -->
                <!--         ColumnDefinitions="Auto, *, Auto, Auto"> -->
                <!--         <components:SvgRender Grid.Column="0"  -->
                <!--                               Name="NodeKindIcon"  -->
                <!--                               Source="{Binding PathSvgIcon, Mode=OneWay}"> -->
                <!--         </components:SvgRender> -->
                <!--         <Grid ClipToBounds="True" ColumnDefinitions="Auto, *" Grid.Column="1"> -->
                <!--             <TextBlock Grid.Column="0" -->
                <!--                        Name="NameText" -->
                <!--                        Text="{Binding Name}" -->
                <!--                        ToolTip.Tip="{Binding AbsolutePath}" -->
                <!--                        HorizontalAlignment="Left" -->
                <!--                        VerticalAlignment="Center"> -->
                <!--             </TextBlock> -->
                <!--             <TextBlock Margin="5 0 0 0" -->
                <!--                        Grid.Column="1" -->
                <!--                        Name="RelativeDirectory" -->
                <!--                        Text="{Binding ContainsDirectory}"> -->
                <!--             </TextBlock> -->
                <!--         </Grid> -->
                <!--         <components:SvgButton Grid.Column="2"  -->
                <!--                               IsVisible="{Binding #ItemRoot.IsPointerOver}" -->
                <!--                               Source="{StaticResource Icons.More}" -->
                <!--                               VerticalAlignment="Center" -->
                <!--                               Name="MoreButton" -->
                <!--                               x:Name="MoreButton" -->
                <!--                               Size="16" -->
                <!--                               EnableFlyout="{Binding MenuItems, Converter={x:Static ObjectConverters.IsNotNull}}" -->
                <!--                               HorizontalAlignment="Right"> -->
                <!--             <components:SvgButton.Flyout> -->
                <!--                 <MenuFlyout Placement="BottomEdgeAlignedLeft" ItemsSource="{Binding MenuItems}"> -->
                <!--                     <MenuFlyout.ItemContainerTheme> -->
                <!--                         <ControlTheme TargetType="MenuItem" -->
                <!--                                       BasedOn="{StaticResource {x:Type MenuItem}}" -->
                <!--                                       x:DataType="vm:MenuItemViewModel"> -->
                <!--                             <Setter Property="Icon" Value="{Binding Icon}"></Setter> -->
                <!--                             <Setter Property="Padding" Value="4 2"></Setter> -->
                <!--                             <Setter Property="Header" Value="{Binding Header}" /> -->
                <!--                             <Setter Property="ItemsSource" Value="{Binding Children}" /> -->
                <!--                             <Setter Property="Command" Value="{Binding Command}" /> -->
                <!--                             <Setter Property="CommandParameter" Value="{Binding CommandParameter}" /> -->
                <!--                             <Setter Property="IsEnabled" Value="{Binding IsEnabled}" /> -->
                <!--                         </ControlTheme> -->
                <!--                     </MenuFlyout.ItemContainerTheme> -->
                <!--                 </MenuFlyout> -->
                <!--             </components:SvgButton.Flyout> -->
                <!--         </components:SvgButton> -->
                <!--         <components:SvgRender -->
                <!--             Name="NodeStatusIcon" -->
                <!--             ToolTip.Tip="{Binding StatusToolTip, Mode=OneWay}" -->
                <!--             Grid.Column="3" -->
                <!--             Source="{Binding StatusSvgIcon, Mode=OneWay}"> -->
                <!--         </components:SvgRender> -->
                <!--     </Grid> -->
                <!-- </Border> -->
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>