    <!--         <SolidColorBrush x:Key="TabItemActivePointeroverBackground" Color="White"></SolidColorBrush> -->
    <!--         <SolidColorBrush x:Key="TabItemInActiveBackground" Color="#D3E3FD"></SolidColorBrush> -->
    <!--         <SolidColorBrush x:Key="TabItemInActivePointeroverBackground" Color="#A8C7FA"></SolidColorBrush> -->
    <!--         <SolidColorBrush x:Key="TabBarBackground" Color="#D3E3FD"></SolidColorBrush> -->
