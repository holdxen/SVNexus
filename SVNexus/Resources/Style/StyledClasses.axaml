<Styles xmlns="https://github.com/avaloniaui"
        xmlns:components="clr-namespace:SVNexus.Components"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:u="https://irihi.tech/ursa">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
        </Border>
    </Design.PreviewWith>

    <Style Selector="Label.VCenter">
        <Setter Property="VerticalAlignment" Value="Center"></Setter>
    </Style>
    
    <Style Selector="Label.HCenter">
        <Setter Property="HorizontalAlignment" Value="Center"></Setter>
    </Style>
    
    <Style Selector="TextBlock.VCenter">
        <Setter Property="VerticalAlignment" Value="Center"></Setter>
    </Style>
    
    <Style Selector="TextBlock.HCenter">
        <Setter Property="HorizontalAlignment" Value="Center"></Setter>
    </Style>
    
    
    <Style Selector="components|LucideIconButton.ToolBarIconButton">
        <Setter Property="Size" Value="22"></Setter>
    </Style>
    
    <Style Selector="MenuItem.Thin">
        <Setter Property="Padding" Value="4 2"></Setter>
    </Style>
    
    <Style Selector="components|SvgRender.Themable">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}"></Setter>
    </Style>
    
    <Style Selector="u|FormItem.GridLayout">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="u:FormItem">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel
                            Grid.Row="0"
                            Name="PART_LabelPanel"
                            Margin="0,0,0,4"
                            HorizontalAlignment="{TemplateBinding LabelAlignment}"
                            Orientation="Horizontal">
                            <Label
                                Name="PART_Label"
                                Content="{TemplateBinding Label}"
                                Background="Transparent"
                                FontWeight="{DynamicResource TextBlockTitleFontWeight}"
                                Target="{Binding #PART_ContentPresenter.Content}" />
                            <TextBlock
                                Foreground="{DynamicResource FormAsteriskForeground}"
                                IsVisible="{TemplateBinding IsRequired}"
                                Text="*" />
                        </StackPanel>
                        <ContentPresenter
                            Grid.Row="1"
                            Name="PART_ContentPresenter"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Content="{TemplateBinding Content}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style Selector="u|DefaultDialogControl.Fixed">
        <Setter Property="(ScrollViewer.HorizontalScrollBarVisibility)" Value="Disabled"></Setter>
        <Setter Property="(ScrollViewer.VerticalScrollBarVisibility)" Value="Disabled"></Setter>
    </Style>
    
    <Style Selector="u|DefaultDialogControl.HStretch">
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
    </Style>
    
    <Style Selector="u|DefaultDialogControl.VStretch">
        <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
    </Style>
    <Style Selector="u|DefaultDialogControl.FixedTheme">
        <Setter Property="Theme" Value="{StaticResource FixedControl}"></Setter>
    </Style>
</Styles>
