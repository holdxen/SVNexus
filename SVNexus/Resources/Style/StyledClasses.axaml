<Styles xmlns="https://github.com/avaloniaui"
        xmlns:components="clr-namespace:SVNexus.Components"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:u="https://irihi.tech/ursa">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
        </Border>
    </Design.PreviewWith>

    <Style Selector="Label.VCenter">
        <Setter Property="VerticalAlignment" Value="Center"></Setter>
    </Style>
    
    <Style Selector="Label.HCenter">
        <Setter Property="HorizontalAlignment" Value="Center"></Setter>
    </Style>
    
    <Style Selector="TextBlock.VCenter">
        <Setter Property="VerticalAlignment" Value="Center"></Setter>
    </Style>
    
    <Style Selector="TextBlock.HCenter">
        <Setter Property="HorizontalAlignment" Value="Center"></Setter>
    </Style>
    
    
    <Style Selector="components|LucideIconButton.ToolBarIconButton">
        <Setter Property="Size" Value="22"></Setter>
    </Style>
    
    <Style Selector="MenuItem.Thin">
        <Setter Property="Padding" Value="4 2"></Setter>
    </Style>
    
    <Style Selector="components|SvgRender.Themable">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}"></Setter>
    </Style>
    
    <Style Selector="TreeViewItem:hasChild /template/ ToggleButton#PART_ExpandCollapseChevron">
        <Setter Property="IsHitTestVisible" Value="True"></Setter>
        <Setter Property="Opacity" Value="1"></Setter>
    </Style>
    
    <Style Selector="components|AdvancedTreeViewItem:loading /template/ ToggleButton#PART_ExpandCollapseChevron">
        <Setter Property="Theme" Value="{x:Null}"></Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="ToggleButton">
                <u:LoadingIcon/>
            </ControlTemplate>
        </Setter>
        <Setter Property="IsHitTestVisible" Value="True"></Setter>
        <Setter Property="Opacity" Value="1"></Setter>
    </Style>
</Styles>
