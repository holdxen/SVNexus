    <system:String x:Key="Icons.Status-Unversioned">
        <![CDATA[
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="none">
  <defs>
    <linearGradient id="bgGrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#F5A623"/>
      <stop offset="100%" stop-color="#E07B00"/>
    </linearGradient>
    <linearGradient id="innerGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFD580"/>
      <stop offset="100%" stop-color="#F5A623"/>
    </linearGradient>
    <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="0.6" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Outer circle with gradient -->
  <circle cx="8" cy="8" r="7.5" fill="url(#bgGrad)" />

  <!-- Inner subtle highlight ring -->
  <circle cx="8" cy="8" r="7.5" fill="none" stroke="#FFD580" stroke-width="0.5" opacity="0.4"/>

  <text
    x="8"
    y="11.4"
    text-anchor="middle"
    font-family="JetBrains Mono"
    font-size="9.5"
    font-weight="700"
    fill="#1A0F00"
    opacity="0.85"
    filter="url(#glow)"
  >?</text>
</svg>

        ]]>
    </system:String>
    
