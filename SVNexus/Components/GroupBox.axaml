<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="using:SVNexus.Components">
    <Design.PreviewWith>
        <components:GroupBox />
    </Design.PreviewWith>

    <Style Selector="components|GroupBox">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">

                    <!-- Header -->
                    <Border Grid.Row="0" Grid.Column="0"
                        ZIndex="1" 
                        Background="{DynamicResource SemiColorBackground2}" 
                        Padding="5,0,5,0" 
                        Margin="5,0,0,0">
                        <TextBlock 
                            Text="{TemplateBinding Title}" 
                            FontWeight="Bold"/>
                    </Border>
        
                    <!-- Content Area -->
                    <Border Grid.Row="0" Grid.Column="0"
                        Grid.RowSpan="2" 
                        Padding="0,5,0,0"
                        Grid.ColumnSpan="2"
                        CornerRadius="4"
                        Margin="0,10,0,0"
                        BorderBrush="Black"
                        BorderThickness="1">
                        <ContentPresenter 
                            Padding="8"
                            Content="{TemplateBinding Content}"/>
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
